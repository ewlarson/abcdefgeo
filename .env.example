VITE_BASE_URL=/
# Optional legacy fallback. New institution themes should prefer theme.yaml api.base_url.
# Defaults point at the public OpenGeoMetadata API root.
VITE_API_BASE_URL=https://ogm.geo4lib.app/api/v1/
VITE_CSRF_TOKEN=replace-with-csrf-token-if-required
VITE_USE_JSONP=false
VITE_APP_VERSION=dev
VITE_ENABLE_DEBUG_LOGS=false
VITE_TURNSTILE_ENABLED=false
VITE_TURNSTILE_SITE_KEY=
VITE_TURNSTILE_ACTION=ogm_viewer_gate
